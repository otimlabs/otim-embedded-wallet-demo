# Chain Configuration
CHAIN_NAME=base-sepolia
# Supported values: "base-sepolia", "sepolia"

# Turnkey Configuration (for pnpm turnkey)
TURNKEY_ORGANIZATION_ID=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=

# Privy Configuration (for pnpm privy)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Wallet Creation
CREATE_NEW_WALLET=true
# Set to 'true' to create a new wallet, or leave unset/false to use existing wallet